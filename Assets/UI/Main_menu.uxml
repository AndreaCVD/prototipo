        <ui:VisualElement name="camera_viewport" style="flex-grow: 1; width: 40%; height: 100%; background-image: url(&quot;project://database/Assets/UI/CamaraVista.renderTexture?fileID=8400000&amp;guid=afffa15d9cd371347b2e3a4364216206&amp;type=2#CamaraVista&quot;); -unity-background-image-tint-color: rgb(255, 255, 255);" />
